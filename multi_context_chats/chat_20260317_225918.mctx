/**
 * ZI Worm Gear Generator - Versão Refatorada (Involute Helicoid)
 * 
 * Gera uma Rosca Sem-Fim ZI utilizando o Método Analítico Transversal exato.
 * 
 * Refatoração Arquitetural:
 * - Domain-Driven Design: Corrigida a nomenclatura e a modelagem matemática de ZN para ZI.
 * - Separation of Concerns: Dividido em CliParser, ZiMath, ProfileGenerator e ScadExporter.
 * - Segurança: Adicionadas validações de I/O, invariantes de domínio e parsing robusto.
 */

#include <iostream>
#include <fstream>
#include <cmath>
#include <vector>
#include <string>
#include <algorithm>
#include <iomanip>
#include <stdexcept>
#include <tuple>

constexpr double PI = 3.14159265358979323846;

// --- Estruturas de Domínio ---

struct ZiWormConfig {
    double mx = 3.0;            // Módulo Axial (Padrão Industrial)
    double mn_override = 0.0;   // Se > 0, calcula mx para atingir este Módulo Normal
    double worm_diam = 40.0;    // Diâmetro Primitivo de Referência (D)
    double alpha_n_deg = 20.0;  // Ângulo de Pressão Normal (graus)
    int    starts = 1;          // Número de entradas (z1)
    double length = 60.0;       // Comprimento total
    int    res_profile = 40;    // Resolução do perfil transversal
    int    res_helix = 72;      // Resolução da hélice em Z
    std::string output = "worm_zi_final.scad";
};

struct Point3 {
    double x, y, z;
};

// --- Componente B: Matemática do Domínio ZI ---

namespace ZiMath {
    inline double deg2rad(double d) { return d * PI / 180.0; }
    
    inline double inv(double angle_rad) { return std::tan(angle_rad) - angle_rad; }

    // Calcula de forma exata e não-iterativa o módulo axial a partir do normal
    inline double calculate_mx(double mn, double D, int starts) {
        double term = (starts * mn) / D;
        double radicand = 1.0 - (term * term);
        
        // Guard Clause: O avanço helicoidal não pode exigir um passo transversal impossível 
        // para o diâmetro atual (violaria o espaço euclidiano do cilindro)
        if (radicand <= 0.0) {
            throw std::domain_error("Erro de Domínio: Impossível calcular mx. "
                                    "A relação z1 * mn excede o diâmetro de referência (D).");
        }
        return mn / std::sqrt(radicand);
    }
}

// --- Componente A: Parse e Sanitização CLI ---

class CliParser {
public:
    static void print_usage(const char* prog_name) {
        std::cerr << "Uso: " << prog_name << " [opcoes]\n"
                  << "Opcoes:\n"
                  << "  -mx <val>      Modulo Axial (padrao: 3.0)\n"
                  << "  -mn <val>      Modulo Normal alvo (sobrepoe mx)\n"
                  << "  -d <val>       Diametro Primitivo (padrao: 40.0)\n"
                  << "  -phi <val>     Angulo de Pressao Normal em graus (padrao: 20.0)\n"
                  << "  -starts <val>  Numero de entradas (padrao: 1)\n"
                  << "  -len <val>     Comprimento total (padrao: 60.0)\n"
                  << "  -out <file>    Arquivo de saida (padrao: worm_zi_final.scad)\n";
    }

    static ZiWormConfig parse(int argc, char** argv) {
        ZiWormConfig p;
        try {
            for (int i = 1; i < argc; ++i) {
                std::string arg = argv[i];
                if (i + 1 < argc) {
                    if      (arg == "-mx")     p.mx = std::stod(argv[++i]);
                    else if (arg == "-mn")     p.mn_override = std::stod(argv[++i]);
                    else if (arg == "-d")      p.worm_diam = std::stod(argv[++i]);
                    else if (arg == "-phi")    p.alpha_n_deg = std::stod(argv[++i]);
                    else if (arg == "-starts") p.starts = std::stoi(argv[++i]);
                    else if (arg == "-len")    p.length = std::stod(argv[++i]);
                    else if (arg == "-out")    p.output = argv[++i];
                }
            }
            
            if (p.starts <= 0) {
                throw std::invalid_argument("Erro de parsing: 'starts' deve ser maior que 0.");
            }
            if (p.worm_diam <= 0.0) {
                throw std::invalid_argument("Erro de parsing: 'd' (diametro) deve ser maior que 0.");
            }
            if (p.mx <= 0.0 && p.mn_override <= 0.0) {
                throw std::invalid_argument("Erro de parsing: modulo deve ser maior que 0.");
            }
        } catch (const std::invalid_argument& e) {
            throw std::invalid_argument(std::string("Argumento invalido: ") + e.what());
        } catch (const std::out_of_range&) {
            throw std::out_of_range("Erro de parsing: valor fora dos limites numericos suportados.");
        }
        return p;
    }
};

// --- Componente C: Geração Transversal Exata ---

class ProfileGenerator {
public:
    static std::tuple<std::vector<Point3>, double, double> generate(const ZiWormConfig& p) {
        const double Rp = p.worm_diam / 2.0;
        const double alpha_n = ZiMath::deg2rad(p.alpha_n_deg);
        
        // Passo da Hélice e Ângulo de Avanço
        const double lead = PI * p.mx * p.starts;
        double out_lambda = std::atan(lead / (PI * p.worm_diam));

        // Correção Matemática 1: Conversão Normal para Transversal exata para ZI (divisão por sin(lambda))
        double out_alpha_t = std::atan(std::tan(alpha_n) / std::sin(out_lambda));
        
        const double Rb = Rp * std::cos(out_alpha_t);
        const double inv_alpha_t = ZiMath::inv(out_alpha_t);

        const double addendum = p.mx;
        const double dedendum = 1.25 * p.mx;
        const double Ra = Rp + addendum;
        const double Rf = Rp - dedendum;

        // Correção Matemática 2: Abertura Angular Exata do vão transversal
        const double half_gap_angle = PI / (2.0 * p.starts);

        if (half_gap_angle <= inv_alpha_t) {
            throw std::domain_error("ERRO FATAL: Undercut geometrico detectado.\n"
                                    "  O perfil involuto transversal colide na base geometrica.\n"
                                    "  Aumente o diametro primitivo ou reduza o modulo.");
        }

        const double theta_offset = half_gap_angle - inv_alpha_t;

        std::vector<Point3> curve_pts;
        double r_start_calc = std::max(Rf, Rb);

        for (int i = 0; i <= p.res_profile; ++i) {
            double r = r_start_calc + (Ra - r_start_calc) * ((double)i / p.res_profile);
            double alpha_curr = std::acos(Rb / r);
            double theta = ZiMath::inv(alpha_curr) + theta_offset;
            curve_pts.push_back({r * std::cos(theta), r * std::sin(theta), 0.0});
        }

        std::vector<Point3> profile;

        // Fundo (Base)
        if (Rf < Rb) {
            double ang = theta_offset;
            profile.push_back({Rf * std::cos(-ang), Rf * std::sin(-ang), 0.0});
            profile.push_back({Rf * std::cos(ang),  Rf * std::sin(ang),  0.0});
        } else {
            Point3 p0 = curve_pts[0];
            profile.push_back({p0.x, -p0.y, 0.0});
            profile.push_back(p0);
        }

        // Lado Direito
        size_t start_idx = (Rf >= Rb) ? 1 : 0;
        for (size_t i = start_idx; i < curve_pts.size(); ++i) {
            profile.push_back(curve_pts[i]);
        }

        // Topo do Dente
        double Ra_safe = Ra * 1.05;
        Point3 last = curve_pts.back();
        double angle_R = std::atan2(last.y, last.x);
        double angle_L = -angle_R;
        
        int steps_top = 8;
        for (int k = 0; k <= steps_top; ++k) {
            double a = angle_R + (angle_L - angle_R) * ((double)k / steps_top);
            profile.push_back({Ra_safe * std::cos(a), Ra_safe * std::sin(a), 0.0});
        }

        // Lado Esquerdo
        for (int i = (int)curve_pts.size() - 1; i >= (int)start_idx; --i) {
            Point3 pt = curve_pts[i];
            profile.push_back({pt.x, -pt.y, 0.0});
        }

        return {profile, out_alpha_t, out_lambda};
    }
};

// --- Componente D: Exportador 3D para OpenSCAD ---

class ScadExporter {
private:
    static Point3 rotate_z(const Point3& p, double theta) {
        double c = std::cos(theta);
        double s = std::sin(theta);
        return { p.x * c - p.y * s, p.x * s + p.y * c, p.z };
    }

public:
    static void export_scad(const ZiWormConfig& p, const std::vector<Point3>& profile, double alpha_t, double lambda) {
        std::ofstream file(p.output);
        if (!file.is_open()) {
            throw std::runtime_error("Erro de I/O: Nao foi possivel abrir ou criar o arquivo " + p.output);
        }

        const double lead = PI * p.mx * p.starts;
        const double Rp = p.worm_diam / 2.0;
        const double Ra = Rp + p.mx;

        file << std::fixed << std::setprecision(5);
        file << "// Worm ZI Generator (Involute Helicoid Transverse Method)\n";
        file << "// Modulo Axial: " << p.mx << "\n";
        file << "// Parametros ZI: Alpha_n=" << p.alpha_n_deg << "deg, Alpha_t=" << (alpha_t * 180.0 / PI) << "deg\n";
        file << "// Lead Angle: " << (lambda * 180.0 / PI) << " deg\n";
        
        double turns = p.length / lead + 0.5;
        double total_angle = 2.0 * PI * turns;
        
        int steps_z = std::max(
            static_cast<int>(turns * p.res_helix),
            static_cast<int>(turns * 16)
        );
        if (steps_z < 24) steps_z = 24;

        double z_start = -p.length / 2.0 - lead * 0.25;

        file << "module worm() {difference() {\n";
        file << "  cylinder(r=" << Ra << ", h=" << p.length << ", center=true, $fn=" << std::max(100, p.res_helix) << ");\n";
        file << "  union() {\n";

        for (int s = 0; s < p.starts; ++s) {
            double offset_angle = (2.0 * PI * s) / p.starts;

            file << "    polyhedron(points=[\n";
            
            for (int i = 0; i <= steps_z; ++i) {
                double u = (double)i / steps_z;
                double theta_helix = u * total_angle;
                double z_pos = z_start + (theta_helix / (2.0 * PI)) * lead;
                
                double rotation = theta_helix + offset_angle;

                for (const auto& pt : profile) {
                    Point3 rot = rotate_z(pt, rotation);
                    file << "      [" << rot.x << "," << rot.y << "," << z_pos << "],\n";
                }
            }

            file << "    ], faces=[\n";
            
            int N = profile.size();
            for (int i = 0; i < steps_z; ++i) {
                int b0 = i * N;
                int b1 = (i + 1) * N;
                for (int j = 0; j < N; ++j) {
                    int jn = (j + 1) % N;
                    file << "      [" << (b0+j) << "," << (b0+jn) << "," << (b1+jn) << "],\n";
                    file << "      [" << (b0+j) << "," << (b1+jn) << "," << (b1+j) << "],\n";
                }
            }
            
            // Tampas de extremidade
            file << "      ["; 
            for(int j = N - 1; j >= 0; --j) file << j << (j == 0 ? "" : ","); 
            file << "],\n";
            
            file << "      ["; 
            for(int j = 0; j < N; ++j) file << (steps_z * N + j) << (j == N - 1 ? "" : ","); 
            file << "]\n";
            
            file << "    ]);\n";
        }

        file << "  }\n}}\n";
        
        file << "\nworm();\n";
        
        file.close();
    }
};

// --- Fluxo Orquestrador Principal ---

int main(int argc, char** argv) {
    try {
        ZiWormConfig config = CliParser::parse(argc, argv);

        // Se o projetista solicitou via Módulo Normal (mn), a matemática prevalece e ajusta o Módulo Axial (mx)
        if (config.mn_override > 0.0) {
            std::cout << "Calculando Modulo Axial analitico para obter Mn=" << config.mn_override << "...\n";
            config.mx = ZiMath::calculate_mx(config.mn_override, config.worm_diam, config.starts);
            std::cout << "  -> Mx fixado: " << std::fixed << std::setprecision(6) << config.mx << "\n";
        }

        // Gera o perfil em seção transversal obedecendo a mecânica conjugada ZI
        auto [profile, alpha_t, lambda] = ProfileGenerator::generate(config);

        // Transfere o plano cartesiano Z=0 para uma torção de sólido em ambiente 3D
        ScadExporter::export_scad(config, profile, alpha_t, lambda);

        std::cout << "\nArquivo gerado com sucesso: " << config.output << "\n";
        std::cout << "  Geometria Confirmada: ZI (Involute Helicoid)\n";
        std::cout << "  Angulo de Pressao Transversal (Alpha_t): " << std::fixed << std::setprecision(4) << (alpha_t * 180.0 / PI) << " deg\n";
        
    } catch (const std::exception& e) {
        std::cerr << "\n[ERRO CRITICO] " << e.what() << "\n\n";
        CliParser::print_usage(argv[0]);
        return 1;
    }

    return 0;
}

