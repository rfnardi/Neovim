{"name": "edit_file", "arguments": {"path": "/home/nardi/repos/worm_zn_generator/tests/test_runner.cpp", "content": "#define UNIT_TEST\n#include \"../src/worm_builder.cpp\"\n#include <iostream>\n#include <cassert>\n#include <cmath>\n#include <stdexcept>\n\n#define ASSERT_THROWS(expr, ExceptionType) \\\n    do { \\\n        bool caught = false; \\\n        try { expr; } \\\n        catch (const ExceptionType&) { caught = true; } \\\n        catch (...) {} \\\n        if (!caught) { \\\n            std::cerr << \"[FALHA] \" << #expr << \" nao lancou a excecao esperada \" << #ExceptionType << \"\\n\"; \\\n            assert(false); \\\n        } \\\n    } while(0)\n\nvoid test_math_happy_path() {\n    // mn = 3, D = 40, starts = 1\n    double mx = ZiMath::calculate_mx(3.0, 40.0, 1);\n    // Validação matemática: \n    // term = (1*3)/40 = 0.075\n    // rad = 1 - 0.075^2 = 1 - 0.005625 = 0.994375\n    // mx = 3 / sqrt(0.994375) = 3 / 0.9971835 = 3.008473\n    assert(std::abs(mx - 3.008473) < 1e-4);\n    std::cout << \"[OK] test_math_happy_path (Calculo de mx)\\n\";\n}\n\nvoid test_math_domain_error() {\n    // Testar quebra do limite de domínio do cilindro. z1 * mn >= D.\n    // Exemplo mn = 5, D = 10, starts = 3 => term = 15/10 = 1.5 => rad < 0.\n    ASSERT_THROWS(ZiMath::calculate_mx(5.0, 10.0, 3), std::domain_error);\n    std::cout << \"[OK] test_math_domain_error (Restricao Radicando)\\n\";\n}\n\nvoid test_parser_defaults() {\n    const char* argv[] = {\"worm_builder\"};\n    ZiWormConfig config = CliParser::parse(1, const_cast<char**>(argv));\n    assert(config.mx == 3.0);\n    assert(config.starts == 1);\n    assert(config.worm_diam == 40.0);\n    assert(config.output == \"worm_zi_final.scad\");\n    std::cout << \"[OK] test_parser_defaults\\n\";\n}\n\nvoid test_parser_invalid_arguments() {\n    // Testar parsing de strings inválidas\n    const char* argv1[] = {\"worm_builder\", \"-starts\", \"abc\"};\n    ASSERT_THROWS(CliParser::parse(3, const_cast<char**>(argv1)), std::invalid_argument);\n\n    // Testar zero onde deveria ser >= 0\n    const char* argv2[] = {\"worm_builder\", \"-starts\", \"0\"};\n    ASSERT_THROWS(CliParser::parse(3, const_cast<char**>(argv2)), std::invalid_argument);\n    \n    const char* argv3[] = {\"worm_builder\", \"-d\", \"-10.0\"};\n    ASSERT_THROWS(CliParser::parse(3, const_cast<char**>(argv3)), std::invalid_argument);\n    std::cout << \"[OK] test_parser_invalid_arguments (Sanitizacao)\\n\";\n}\n\nvoid test_generator_happy_path() {\n    ZiWormConfig config;\n    config.mx = 3.0;\n    config.worm_diam = 40.0;\n    config.starts = 1;\n    config.alpha_n_deg = 20.0;\n    \n    auto [profile, alpha_t, lambda] = ProfileGenerator::generate(config);\n    \n    // alpha_t sempre deve ser maior que alpha_n para perfil helicoidal\n    double alpha_n = ZiMath::deg2rad(20.0);\n    assert(alpha_t > alpha_n);\n    \n    // Verificar se gerou os pontos de profile\n    assert(profile.size() > 10);\n    std::cout << \"[OK] test_generator_happy_path (Profile gerado)\\n\";\n}\n\nvoid test_generator_undercut() {\n    // Forçar Undercut: Módulo muito grande, diâmetro minúsculo e muitas entradas\n    ZiWormConfig config;\n    config.mx = 10.0;\n    config.worm_diam = 15.0;\n    config.starts = 8;\n    config.alpha_n_deg = 20.0;\n\n    ASSERT_THROWS(ProfileGenerator::generate(config), std::domain_error);\n    std::cout << \"[OK] test_generator_undercut (Protecao Topologica)\\n\";\n}\n\nint main() {\n    std::cout << \"========================================\\n\";\n    std::cout << \"INICIANDO TESTES UNITARIOS ZI WORM GEOM\\n\";\n    std::cout << \"========================================\\n\";\n    \n    test_math_happy_path();\n    test_math_domain_error();\n    test_parser_defaults();\n    test_parser_invalid_arguments();\n    test_generator_happy_path();\n    test_generator_undercut();\n    \n    std::cout << \"========================================\\n\";\n    std::cout << \"TODOS OS TESTES PASSARAM COM SUCESSO!\\n\";\n    std::cout << \"========================================\\n\";\n    return 0;\n}\n"}}
