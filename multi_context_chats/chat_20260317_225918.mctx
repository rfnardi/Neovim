55.8581,0.00810687],[55.8586,0.00832003],[55.8592,0.0085332],[55.8598,0.00874638],[55.8603,0.00895956],[55.8609,0.0091461],[55.8615,0.00935929],[55.862,0.00957248],[55.8626,0.00975904],[55.8632,0.0099456],[55.8637,0.0101588],[55.8643,0.0103454],[55.8649,0.010532],[55.8654,0.0106919],[55.866,0.0108785],[55.8666,0.0110384],[55.8672,0.011225],[55.8677,0.0114116],[55.8683,0.0115716],[55.8689,0.0117315],[55.8695,0.0118915],[55.87,0.0120515],[55.8706,0.0122114],[55.8712,0.0123448],[55.8718,0.0125047],[55.8724,0.0126647],[55.8729,0.0127981],[55.8735,0.0129314],[55.8741,0.0130914],[55.8747,0.0131981],[55.8753,0.0133581],[55.8759,0.0134915],[55.8765,0.0135982],[55.877,0.0137316],[55.8776,0.0138383],[55.8782,0.0139717],[55.8788,0.014105],[55.8794,0.0142118],[55.88,0.0143185],[55.8806,0.0144252],[55.8812,0.014532],[55.8818,0.0146121],[55.8823,0.0146921],[55.8829,0.0148255],[55.8835,0.0149056],[55.8841,0.0149857],[55.8847,0.0150658],[55.8853,0.0151726],[55.8859,0.0152527],[55.8865,0.0153062],[55.8871,0.0154129],[55.8877,0.0154664],[55.8883,0.0155198],[55.8889,0.0156],[55.8895,0.0156534],[55.8901,0.0157069],[55.8907,0.015787],[55.8913,0.0158405],[55.8919,0.0158673],[55.8925,0.0159208],[55.8931,0.0159476],[55.8937,0.0160277],[55.8943,0.0160546],[55.8949,0.0160814],[55.8955,0.0161082],[55.8961,0.016135],[55.8967,0.0161619],[55.8973,0.0162153],[55.8979,0.0162155],[55.8985,0.0162423],[55.8991,0.0162425],[55.8997,0.0162693],[55.9003,0.0162695],[55.9009,0.0162697],[55.9015,0.0162699],];

module gear(){linear_extrude(convexity = 15, height=20, twist=0, slices=0){polygon(points);};};

module rasgo_eixo_c_chaveta(largura, altura, raio_eixo, raio_filete, height){
	linear_extrude(25){
		union(){
			circle(raio_eixo, $fn=200);
			hull(){
				translate([raio_eixo + altura - raio_filete, largura/2 - raio_filete, 0]) circle(raio_filete, $fn=200);
				translate([raio_eixo + altura - raio_filete, -largura/2 + raio_filete, 0]) circle(raio_filete, $fn=200);
				translate([0, -largura/2 + raio_filete, 0]) circle(raio_filete, $fn=200);
				translate([0, largura/2 - raio_filete, 0]) circle(raio_filete, $fn=200);
			};
		}
	}
}

difference(){
	gear();
	translate([0,0,-2])rasgo_eixo_c_chaveta(6, 2.8, 10, 0.25, 24);
};

== Arquivo: /home/nardi/repos/worm_zn_generator/src/worm_builder.cpp ==
/**
 * ZN Worm Gear Generator - Versão Final Otimizada
 * 
 * Gera uma Rosca Sem-Fim ZN (Involuta Normal) utilizando o Método Analítico Transversal.
 * 
 * Lógica de Correção Aplicada:
 * 1. Converte parâmetros Normais (alpha_n) para Transversais (alpha_t).
 * 2. Gera o perfil INVOLUTO TRANSVERSAL exato no plano Z=0.
 * 3. Extruda helicoidalmente.
 * 
 * Nota: O "Tilt" geométrico (Correção 2) foi substituído pela conversão analítica (Correção 1),
 * pois gerar o perfil transversal correto é mais preciso para a malha do OpenSCAD 
 * do que inclinar polígonos no espaço.
 */

#include <iostream>
#include <fstream>
#include <cmath>
#include <vector>
#include <string>
#include <algorithm>
#include <iomanip>

constexpr double PI = 3.14159265358979323846;

// --- Estruturas ---

struct WormParams {
    double mx = 3.0;            // Módulo Axial (Padrão Industrial)
    double mn_override = 0.0;   // Se > 0, calcula mx para atingir este Módulo Normal
    double worm_diam = 40.0;    // Diâmetro Primitivo de Referência
    double alpha_n_deg = 20.0;  // Ângulo de Pressão Normal (graus)
    int    starts = 1;          // Número de entradas
    double length = 60.0;       // Comprimento total
    int    res_profile = 40;    // Resolução do perfil
    int    res_helix = 72;      // Resolução da hélice
    std::string output = "worm_zn_final.scad";
};

struct Point3 {
    double x, y, z;
};

// --- Funções Auxiliares ---

double deg2rad(double d) { return d * PI / 180.0; }
double inv(double angle_rad) { return std::tan(angle_rad) - angle_rad; }

// Rotaciona em torno de Z
Point3 rotate_z(const Point3& p, double theta) {
    double c = std::cos(theta);
    double s = std::sin(theta);
    return { p.x * c - p.y * s, p.x * s + p.y * c, p.z };
}

// Resolve mx dado mn (Iterativo, pois mx afeta lambda e lambda afeta a conversão)
double solve_mx_from_mn(double mn_target, double D, int starts) {
    double mx_guess = mn_target; // Primeiro chute
    for(int i=0; i<10; ++i) {
        double lead = PI * mx_guess * starts;
        double lambda = std::atan(lead / (PI * D));
        double mn_calc = mx_guess * std::cos(lambda);
        
        if(std::abs(mn_calc - mn_target) < 1e-6) break;
        
        // Ajuste simples
        mx_guess = mx_guess * (mn_target / mn_calc);
    }
    return mx_guess;
}

void parse_args(int argc, char** argv, WormParams& p) {
    for (int i = 1; i < argc; ++i) {
        std::string arg = argv[i];
        if (i + 1 < argc) {
            if      (arg == "-mx")     p.mx = std::stod(argv[++i]);
            else if (arg == "-mn")     p.mn_override = std::stod(argv[++i]);
            else if (arg == "-d")      p.worm_diam = std::stod(argv[++i]);
            else if (arg == "-phi")    p.alpha_n_deg = std::stod(argv[++i]);
            else if (arg == "-starts") p.starts = std::stoi(argv[++i]);
            else if (arg == "-len")    p.length = std::stod(argv[++i]);
            else if (arg == "-out")    p.output = argv[++i];
        }
    }
}

// --- Main ---

int main(int argc, char** argv) {
    WormParams p;
    parse_args(argc, argv, p);

    // 1. Definição do Módulo Axial (mx)
    double mx = p.mx;
    if (p.mn_override > 0.0) {
        std::cout << "Calculando Módulo Axial para obter Mn=" << p.mn_override << "...\n";
        mx = solve_mx_from_mn(p.mn_override, p.worm_diam, p.starts);
        std::cout << "  -> Mx calculado: " << mx << "\n";
    }

    // 2. Parâmetros Geométricos Fundamentais
    const double Rp = p.worm_diam / 2.0;
    const double alpha_n = deg2rad(p.alpha_n_deg);

    // Lead (Passo da Hélice)
    const double lead = PI * mx * p.starts;
    
    // Ângulo de Avanço (Lead Angle) lambda
    const double lambda = std::atan(lead / (PI * p.worm_diam));

    // --- CORREÇÃO 1: Matemática Transversal (O Coração do ZN) ---
    // Para gerar um sem-fim ZN correto usando extrusão helicoidal padrão,
    // devemos usar o Ângulo de Pressão Transversal (alpha_t).
    // tan(alpha_t) = tan(alpha_n) / cos(lambda)
    const double alpha_t = std::atan(std::tan(alpha_n) / std::cos(lambda));
    
    // Raio Base Transversal
    // A involuta gerada com este raio base no plano Z=0 corresponderá 
    // exatamente ao perfil normal alpha_n quando vista perpendicularmente à hélice.
    const double Rb = Rp * std::cos(alpha_t);
    const double inv_alpha_t = inv(alpha_t);

    // Alturas (baseadas no Módulo Axial, padrão para parafusos)
    const double addendum = mx;
    const double dedendum = 1.25 * mx; // Pode variar conforme norma (ex: 1.167 a 1.25)
    const double Ra = Rp + addendum;
    const double Rf = Rp - dedendum;

    // Largura do Gap no Transversal
    // Espessura axial nominal = PI * mx / 2
    // Largura angular no primitivo = (PI * mx / 2) / Rp
    const double gap_angle_at_Rp = (PI * mx / 2.0) / Rp;
    const double half_gap_angle = gap_angle_at_Rp / 2.0;

    // Verificação de Geometria
    if (half_gap_angle <= inv_alpha_t) {
        std::cerr << "ERRO FATAL: Undercut geometrico.\n"
                  << "  O perfil involuto colide na base.\n"
                  << "  Aumente o diametro ou reduza o modulo.\n";
        return 1;
    }

    // Offset para centralizar o gap (Baseado na geometria Transversal)
    const double theta_offset = half_gap_angle - inv_alpha_t;

    // 3. Geração do Perfil 2D (Plano Transversal Z=0)
    std::vector<Point3> curve_pts;
    
    // Define início da curva (Raio Base ou Raio de Fundo, o que for maior)
    double r_start_calc = (Rf < Rb) ? Rb : Rf;

    for (int i = 0; i <= p.res_profile; ++i) {
        double r = r_start_calc + (Ra - r_start_calc) * ((double)i / p.res_profile);
        
        // Ângulo de pressão transversal neste raio r
        double alpha_curr = std::acos(Rb / r);
        
        // Ângulo polar theta
        double theta = inv(alpha_curr) + theta_offset;

        // Gera ponto no plano XY (Transversal)
        curve_pts.push_back({r * std::cos(theta), r * std::sin(theta), 0.0});
    }

    // Montagem do Polígono do Cortador
    std::vector<Point3> profile;

    // Fundo (Base)
    if (Rf < Rb) {
        double ang = theta_offset; // inv(0) = 0 na base
        profile.push_back({Rf * std::cos(-ang), Rf * std::sin(-ang), 0.0});
        profile.push_back({Rf * std::cos(ang),  Rf * std::sin(ang),  0.0});
    } else {
        Point3 p0 = curve_pts[0];
        profile.push_back({p0.x, -p0.y, 0.0});
        profile.push_back(p0);
    }

    // Lado Direito
    size_t start_idx = (Rf >= Rb) ? 1 : 0;
    for (size_t i = start_idx; i < curve_pts.size(); ++i) {
        profile.push_back(curve_pts[i]);
    }

    // Topo (Arco Correção 1 - Adaptada)
    {
        double Ra_safe = Ra * 1.05;
        Point3 last = curve_pts.back();
        double angle_R = std::atan2(last.y, last.x);
        double angle_L = -angle_R;
        
        int steps_top = 8;
        for (int k = 0; k <= steps_top; ++k) {
            double a = angle_R + (angle_L - angle_R) * ((double)k / steps_top);
            profile.push_back({Ra_safe * std::cos(a), Ra_safe * std::sin(a), 0.0});
        }
    }

    // Lado Esquerdo
    for (int i = curve_pts.size() - 1; i >= (int)start_idx; --i) {
        Point3 pt = curve_pts[i];
        profile.push_back({pt.x, -pt.y, 0.0});
    }

    // NOTA: A "Correção 2" (apply_zn_tilt) não é aplicada aqui.
    // Como geramos o perfil usando alpha_t (transversal), ele já é a projeção correta
    // do ZN no plano Z=0. Inclinar os pontos agora distorceria a geometria.

    // 4. Exportação
    std::ofstream file(p.output);
    file << std::fixed << std::setprecision(5);
    file << "// Worm ZN Generator (Analytic Transverse Method)\n";
    file << "// Modulo Axial: " << mx << "\n";
    file << "// Parametros ZN: Alpha_n=" << p.alpha_n_deg << "deg, Alpha_t=" << (alpha_t*180/PI) << "deg\n";
    file << "// Lead Angle: " << (lambda * 180.0 / PI) << " deg\n";
    
    double turns = p.length / lead + 0.5; // Margem
    double total_angle = 2.0 * PI * turns;
    
    // --- CORREÇÃO 3: Discretização Robusta ---
    int steps_z = std::max(
        static_cast<int>(turns * p.res_helix),
        static_cast<int>(turns * 16) // Minimo 16 passos por volta
    );
    // Piso absoluto para peças muito curtas
    if (steps_z < 24) steps_z = 24;

    double z_start = -p.length / 2.0 - lead * 0.25;

    file << "module worm() {difference() {\n";
    file << "  cylinder(r=" << Ra << ", h=" << p.length << ", center=true, $fn=" << std::max(100, p.res_helix) << ");\n";
    file << "  union() {\n";

    for (int s = 0; s < p.starts; ++s) {
        double offset_angle = (2.0 * PI * s) / p.starts;

        file << "    polyhedron(points=[\n";
        
        for (int i = 0; i <= steps_z; ++i) {
            double u = (double)i / steps_z;
            double theta_helix = u * total_angle;
            double z_pos = z_start + (theta_helix / (2.0 * PI)) * lead;
            
            // Rotação total para este slice
            double rotation = theta_helix + offset_angle;

            for (const auto& pt : profile) {
                // Rotação helicoidal simples (sem tilt extra)
                Point3 rot = rotate_z(pt, rotation);
                file << "      [" << rot.x << "," << rot.y << "," << z_pos << "],\n";
            }
        }

        file << "    ], faces=[\n";
        
        int N = profile.size();
        for (int i = 0; i < steps_z; ++i) {
            int b0 = i * N;
            int b1 = (i + 1) * N;
            for (int j = 0; j < N; ++j) {
                int jn = (j + 1) % N;
                // Ordem CCW
                file << "      [" << (b0+j) << "," << (b0+jn) << "," << (b1+jn) << "],\n";
                file << "      [" << (b0+j) << "," << (b1+jn) << "," << (b1+j) << "],\n";
            }
        }
        
        // Tampas
        file << "      ["; 
        for(int j=N-1; j>=0; --j) file << j << (j==0?"":","); 
        file << "],\n";
        
        file << "      ["; 
        for(int j=0; j<N; ++j) file << (steps_z*N + j) << (j==N-1?"":","); 
        file << "]\n";
        
        file << "    ]);\n";
    }

    file << "  }\n}}\n";
    file.close();

    std::cout << "Arquivo gerado: " << p.output << "\n";
    std::cout << "  Tipo: ZN (Normal Involute)\n";
    std::cout << "  Alpha_t (calculado): " << (alpha_t*180/PI) << " deg\n";
    std::cout << "  Passos Helix: " << steps_z << "\n";
    
    return 0;
}

