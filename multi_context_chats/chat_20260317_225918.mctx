== Arquivo: /home/nardi/repos/worm_zn_generator/tests/test_basic.sh ==
#!/bin/bash

echo "Executando teste básico..."

# ../worm_builder -mn 3 -d 40 -phi 20 -starts 1 -len 60 -out test.scad

../worm_builder \
  -mn 3.0 \
  -d 40.0 \
  -phi 20.0 \
  -starts 1 \
  -len 80 \
  -out W1.scad

echo "Arquivo gerado."

